# Repo root `.env` — loaded by the backend (see backend/src/loadEnv.ts) and prisma.config.ts.
# Copy to `.env` and fill in. Prefer keeping secrets here; backend/.env is optional overrides.

# DATABASE_URL="postgresql://...@....pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# JWT_SECRET="long-random-string"
# ADMIN_SEED_SECRET="at-least-8-chars"
# PORT=3001
#
# Backend — Supabase Storage for avatars & logos (optional; see backend/.env.example):
# SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."
# SUPABASE_STORAGE_BUCKET="caretip"
# SUPABASE_KYC_STORAGE_BUCKET="caretip-kyc"
# Optional — PostgREST bypass tests in npm run test:supabase-security:live (server only, never in SPA):
# SUPABASE_ANON_KEY="eyJhbG..."

# Deprecated — Cloudinary is not used by CareTip (uploads use Supabase Storage). Remove from local .env if present.
# CLOUDINARY_API_KEY= CLOUDINARY_CLOUD_NAME= CLOUDINARY_API_SECRET=

# Frontend (Vite) — optional `.env.local` at repo root
# Omit VITE_API_URL in local dev to use the Vite proxy: /api → http://localhost:3001
# VITE_API_URL=http://localhost:3001
#
# Ask CareTip landing assistant (MVP default: off). Set to true to show the floating chat launcher.
# VITE_ENABLE_AI_ASSISTANT=false
#
# Netlify / dashboard: set the variable **value** to the URL only (e.g. https://api.onrender.com).
# Do not paste `VITE_API_URL=https://...` into the value field — that breaks the client (404 on /VITE_API_URL=...).
#
# Production QR / share links (recommended): absolute SPA origin, no trailing slash.
# Picked up at `vite build` / dev server start (see vite.config.ts → import.meta.env.VITE_CARETIP_APP_ORIGIN).
# BASE_URL=https://caretip.de
#
# Optional overrides (first non-empty wins after BASE_URL in vite’s merge): URL only, https://…
# VITE_BASE_URL=https://caretip.de
# NEXT_PUBLIC_BASE_URL=https://caretip.de
# NEXT_PUBLIC_APP_URL=https://caretip.de
#
# Legacy (avoid if possible): same meaning — value must be the URL only (https://…).
# VITE_APP_URL=https://your-deployed-domain.com
#
# Google Sign-In (SPA) — Web client ID from Google Cloud Console (OAuth 2.0 Client IDs → Web application).
# Production **Authorized JavaScript origins** (both required if users can open either host):
#   https://caretip.de
#   https://www.caretip.de
# Local dev (optional): http://localhost:5173 and/or http://127.0.0.1:5173
# GSI 403 / “origin is not allowed” = missing the exact browser origin (scheme + host + port).
# Frontend (Vite) — same Web client ID as backend GOOGLE_CLIENT_ID (required for Google sign-in button).
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
#
# Google Cloud Console → APIs & Services → Credentials → your Web client:
# Authorized JavaScript origins must include http://localhost:5173 (local dev).
#
# Error monitoring (Sentry) — optional in dev; set in production for crash and API failure visibility.
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_RELEASE=caretip-frontend@1.0.0
#
 Firebase web push (optional) — same values as backend FIREBASE_WEB_*; used by Vite + generate-fcm-sw.mjs
 VITE_FIREBASE_API_KEY=
 VITE_FIREBASE_PROJECT_ID=
 VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
#VITE_FIREBASE_STORAGE_BUCKET=

# --- Playwright (E2E) — optional; see README “Playwright (E2E)” ---
# Skip auto browser download before `npm run test:e2e` (core app / `npm run dev` never runs this).
# SKIP_PLAYWRIGHT_INSTALL=true
# Custom browser binary if `npx playwright install` fails (Windows example):
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Or use installed Google Chrome instead of downloaded Chromium:
# PLAYWRIGHT_USE_SYSTEM_CHROME=true
# Corporate network / mirror (also supported: HTTP_PROXY, HTTPS_PROXY):
# PLAYWRIGHT_DOWNLOAD_HOST=https://playwright.azureedge.net
# PLAYWRIGHT_INSTALL_TIMEOUT_MS=600000
# Leave stall off (default): Playwright is often silent for many minutes after download while extracting.
# PLAYWRIGHT_INSTALL_STALL_MS=0
# If you must enable it, use a large value (e.g. 900000), not 180000 — low values cause false kills on Windows.
# PLAYWRIGHT_INSTALL_RETRY_COOLDOWN_MS=10000
