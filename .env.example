# Repo root `.env` — loaded by the backend (see backend/src/loadEnv.ts) and prisma.config.ts.
# Copy to `.env` and fill in. Prefer keeping secrets here; backend/.env is optional overrides.

# DATABASE_URL="postgresql://...@....pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# JWT_SECRET="long-random-string"
# ADMIN_SEED_SECRET="at-least-8-chars"
# PORT=3001

# Frontend (Vite) — optional `.env.local` at repo root
# Omit VITE_API_URL in local dev to use the Vite proxy: /api → http://localhost:3001
# VITE_API_URL=http://localhost:3001
#
# Netlify / dashboard: set the variable **value** to the URL only (e.g. https://api.onrender.com).
# Do not paste `VITE_API_URL=https://...` into the value field — that breaks the client (404 on /VITE_API_URL=...).
#
# Customer-facing origin used in QR codes and share links (NOT the API host).
# Dev: http://localhost:5173 (or http://localhost:3000 if you serve the SPA there)
# Production: https://your-deployed-domain.com
# VITE_APP_URL=http://localhost:5173
# NEXT_PUBLIC_APP_URL=https://your-deployed-domain.com
#
# Google Sign-In (SPA) — Web client ID from Google Cloud Console
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
