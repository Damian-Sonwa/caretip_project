    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
