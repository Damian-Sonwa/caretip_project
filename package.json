{
  "name": "caretip-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "sync-font-assets": "node scripts/sync-font-assets.mjs",
    "prebuild": "node scripts/generate-pwa-icons.mjs && node scripts/sync-font-assets.mjs && node scripts/optimize-lcp-images.mjs && node scripts/generate-fcm-sw.mjs",
    "predev": "node scripts/sync-font-assets.mjs && node scripts/generate-fcm-sw.mjs",
    "build": "vite build",
    "dev": "vite",
    "dev:api": "npm --prefix backend run dev",
    "db:migrate:resolve": "npm --prefix backend run db:migrate:resolve --",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix --report-unused-disable-directives",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json}\" \"vite.config.ts\"",
    "playwright:install": "node scripts/install-playwright.mjs",
    "pretest:e2e": "node scripts/install-playwright.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:with-server": "node scripts/playwright-with-server.mjs",
    "test:xss-audit": "node scripts/xss-audit.mjs",
    "test:csp": "node scripts/csp-verify.mjs",
    "test:csrf-audit": "node scripts/csrf-audit.mjs",
    "test:secret-exposure": "npm --prefix backend run test:secret-exposure",
    "test:subscription-entitlements-frontend": "node ./backend/node_modules/tsx/dist/cli.mjs ./scripts/subscription-entitlements-frontend-runtime.ts",
    "test:subscription-billing-ux-frontend": "node ./backend/node_modules/tsx/dist/cli.mjs ./scripts/subscription-billing-ux-frontend-runtime.ts",
    "test:subscription-migration-frontend": "node ./backend/node_modules/tsx/dist/cli.mjs ./scripts/subscription-migration-frontend-runtime.ts"
  },
