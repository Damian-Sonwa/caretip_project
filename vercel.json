{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!assets/)(?!api/)(?!uploads/)(?!.*\\.(?:ico|png|jpe?g|gif|svg|webp|woff2?|ttf|js|mjs|css|json|webmanifest|map|txt)$).*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
