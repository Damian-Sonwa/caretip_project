{
  "name": "caretip-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "dev": "tsx watch src/index.ts",
    "env:check": "tsx src/checkEnvCli.ts",
    "build": "prisma generate --schema=prisma/schema.prisma && tsc",
    "start": "node scripts/runMigrateDeploy.mjs && node dist/index.js",
    "prisma": "dotenv -e ../.env -e .env -- prisma",
    "db:generate": "dotenv -e ../.env -e .env -- prisma generate --schema=prisma/schema.prisma",
    "db:prisma:reset-client": "node -e \"require('fs').rmSync(require('path').join('node_modules','.prisma'),{recursive:true,force:true});\" && npm run db:generate",
    "db:push": "dotenv -e ../.env -e .env -- prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "dotenv -e ../.env -e .env -- prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy": "node scripts/runMigrateDeploy.mjs",
    "db:verify-dashboard-indexes": "dotenv -e ../.env -e .env -- tsx scripts/verify-dashboard-indexes.ts",
    "db:migrate:resolve": "dotenv -e ../.env -e .env -- prisma migrate resolve --schema=prisma/schema.prisma",
    "db:check-role": "tsx scripts/check-role-enum.ts",
    "db:migrate:reset": "dotenv -e ../.env -e .env -- prisma migrate reset --force --schema=prisma/schema.prisma",
    "db:setup:dev": "npm run db:migrate:reset && npm run db:generate && npm run db:backfill-business-slugs",
    "db:studio": "dotenv -e ../.env -e .env -- prisma studio --schema=prisma/schema.prisma",
    "db:test": "tsx scripts/test-db.ts",
    "db:signin-smoke": "tsx scripts/signin-smoke.ts",
    "db:employee-verify-guard": "tsx scripts/employee-verify-guard-runtime.ts",
    "test:sprint2-security": "dotenv -e ../.env -e .env -- tsx scripts/sprint2-security-guard-runtime.ts",
    "test:sprint3-guest-flow": "dotenv -e ../.env -e .env -- tsx scripts/sprint3-guest-flow-runtime.ts",
    "test:sprint3-kyc": "dotenv -e ../.env -e .env -- tsx scripts/sprint3-kyc-runtime.ts",
    "test:sprint4-payment-e2e": "dotenv -e ../.env -e .env -- tsx scripts/sprint4-payment-e2e-runtime.ts",
    "test:sprint4-tenant-isolation": "dotenv -e ../.env -e .env -- tsx scripts/sprint4-tenant-isolation-runtime.ts",
    "test:sprint4-employee-lifecycle": "dotenv -e ../.env -e .env -- tsx scripts/sprint4-employee-lifecycle-runtime.ts",
    "db:backfill-business-slugs": "tsx scripts/backfill-business-slugs.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:platform-analytics-demo": "tsx prisma/seedPlatformAnalyticsDemo.ts",
    "smoke:timezone": "tsx src/scripts/smokeTimezone.ts",
    "smoke:tip-payment-eligibility": "dotenv -e ../.env -e .env -- tsx scripts/tip-payment-eligibility-smoke.ts",
    "verify:goal-timezone": "tsx src/scripts/verifyGoalTimezoneSync.ts",
    "audit:landing-ai": "tsx src/scripts/auditLandingAi.ts",
    "db:backfill-slugs": "tsx prisma/backfill-slugs.ts",
    "admin:create": "tsx scripts/createAdmin.js",
    "admin:create:extra": "node scripts/runCreateAdminExtra.mjs",
    "admin:verify": "tsx scripts/verify-platform-admin.ts",
    "db:mark-email-verified": "tsx scripts/markAllUsersEmailVerified.ts",
    "db:backfill-pending-employee-users": "tsx scripts/backfillPendingEmployeeUsers.ts",
    "db:sync-active-employee-email-verified": "tsx scripts/syncActiveEmployeeEmailVerified.ts",
    "db:repair-logo-urls": "dotenv -e ../.env -e .env -- tsx scripts/repairMisconfiguredSupabaseLogoUrls.ts",
    "storage:list-logos": "dotenv -e ../.env -e .env -- tsx scripts/listSupabaseLogoObjects.ts",
    "storage:migrate-official-bucket": "dotenv -e ../.env -e .env -- tsx scripts/migrateStorageBucketOfficialToCaretip.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.13.0",
    "@sentry/node": "^10.57.0",
    "@supabase/supabase-js": "^2.105.4",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.11.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
