# Supabase — copy **one** pooler URL from Dashboard → Connect (Transaction or Session).
# Avoid putting `db.*.supabase.co` in the app .env on Windows — it often causes Prisma P1001; use the pooler host only.
#
# Prisma Migrate: `npx prisma migrate deploy` often stalls on the transaction pooler (6543), and we do not use
# `directUrl` (direct host fails here). To apply a migration without deploy: open the SQL file under
# `backend/prisma/migrations/<name>/migration.sql` in Supabase → SQL Editor, run it, then from `backend/`:
#   npx prisma migrate resolve --applied <migration_folder_name>
# Example (rejected verification status) — run from repo root:
#   npm run db:migrate:resolve -- --applied 20260329120000_add_rejected_verification_status
# Or from `backend/`:
#   npm run db:migrate:resolve -- --applied 20260329120000_add_rejected_verification_status
# Or: npx prisma migrate resolve --schema prisma/schema.prisma --applied 20260329120000_add_rejected_verification_status

# Transaction pooler (example)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Session pooler (example — port 5432, no pgbouncer params)
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Required for JWT auth (use a long random string in production)
JWT_SECRET="long-random-secret-replace-in-production"

# Required for npm run admin:create (≥ 8 characters; never commit real values)
ADMIN_SEED_SECRET="long-random-secret-for-admin-creation"

# Stripe — optional until you enable card checkout / webhooks. Omit entirely for deploys that only need auth + dashboards.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable key (optional on server — for future Payment Element / config; frontend may use VITE_STRIPE_PUBLISHABLE_KEY)
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Customer Checkout success/cancel redirects — must match the deployed SPA origin (same as root VITE_APP_URL / NEXT_PUBLIC_APP_URL).
# Dev (Vite): http://localhost:5173 — or http://localhost:3000 if you serve the built app there
FRONTEND_URL="http://localhost:5173"

# Password reset emails (optional). Without RESEND_API_KEY, the server logs the reset URL in development only.
# RESEND_API_KEY="re_..."
# RESEND_FROM="CareTip <onboarding@resend.dev>"

# Google OAuth — verify ID tokens from the SPA (same OAuth client as VITE_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Server
PORT=3001

# Profile photo uploads (production): use Cloudinary — most hosts provide a single CLOUDINARY_URL.
# Without Cloudinary, files are stored under ./uploads (needs persistent disk) and URLs use PUBLIC_API_BASE_URL.
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# Or: CLOUDINARY_CLOUD_NAME=... CLOUDINARY_API_KEY=... CLOUDINARY_API_SECRET=...
# PUBLIC_API_BASE_URL="https://your-api.example.com"

# Sign-in brute-force protection (optional overrides)
# AUTH_LOGIN_MAX_PER_WINDOW=30

# Verbose [auth.login] console.debug (email + userExists + passwordValid; never logs password). Default on in non-production.
# AUTH_DEBUG_LOGIN=true

# Super Admin seed script extras (optional)
# ALLOW_ADMIN_SEED_IN_PRODUCTION=false
# ALLOW_MULTIPLE_SUPER_ADMINS=false
