# Supabase — copy **one** pooler URL from Dashboard → Connect (Transaction or Session).
# Avoid putting `db.*.supabase.co` in the app .env on Windows — it often causes Prisma P1001; use the pooler host only.
#
# Prisma Migrate: `npx prisma migrate deploy` often stalls on the transaction pooler (6543), and we do not use
# `directUrl` (direct host fails here). To apply a migration without deploy: open the SQL file under
# `backend/prisma/migrations/<name>/migration.sql` in Supabase → SQL Editor, run it, then from `backend/`:
#   npx prisma migrate resolve --applied <migration_folder_name>
# Example (rejected verification status) — run from repo root:
#   npm run db:migrate:resolve -- --applied 20260329120000_add_rejected_verification_status
# Or from `backend/`:
#   npm run db:migrate:resolve -- --applied 20260329120000_add_rejected_verification_status
# Or: npx prisma migrate resolve --schema prisma/schema.prisma --applied 20260329120000_add_rejected_verification_status

# Transaction pooler — use this on Render/Vercel production (required for Prisma runtime)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Session pooler (5432) — migrations only (npm start runs migrate on 5432 via scripts/sessionDatabaseUrl.mjs).
# If you paste a 5432 URL into Render, the API auto-rewrites runtime to 6543 unless DATABASE_USE_SESSION_POOLER=true.
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Required for JWT auth (use a long random string in production)
JWT_SECRET="long-random-secret-replace-in-production"
# Access token TTL (default 15m). Refresh uses HttpOnly cookie + DB rotation (see REFRESH_TOKEN_EXPIRES_DAYS).
# JWT_EXPIRES_IN="15m"
# REFRESH_TOKEN_EXPIRES_DAYS="7"

# Required for npm run admin:create (≥ 8 characters; never commit real values)
ADMIN_SEED_SECRET="long-random-secret-for-admin-creation"

# Stripe — optional until you enable card checkout / webhooks. Omit entirely for deploys that only need auth + dashboards.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Publishable key (optional on server — for future Payment Element / config; frontend may use VITE_STRIPE_PUBLISHABLE_KEY)
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Customer Checkout success/cancel redirects — must match the deployed SPA origin (same as users open in the browser; optional root NEXT_PUBLIC_APP_URL if you override QR base).
# Dev (Vite): http://localhost:5173 — or http://localhost:3000 if you serve the built app there
FRONTEND_URL="http://localhost:5173"

# Transactional email (Resend). Without RESEND_API_KEY, the server logs links in development only.
# RESEND_API_KEY="re_..."
# RESEND_FROM must be `email@domain` or `Name <email@domain>` (verified in Resend). A bare domain like `caretip.de` returns 422.
# RESEND_FROM="CareTip <onboarding@resend.dev>"
# RESEND_FROM="CareTip <noreply@your-verified-domain.com>"

# Google OAuth — verify ID tokens from the SPA (same OAuth client as VITE_GOOGLE_CLIENT_ID in repo root .env).
# If unset, the API falls back to VITE_GOOGLE_CLIENT_ID when both are loaded from the same root .env.
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Optional: extend who can sign in without clicking the inbox verification link (password or Google).
# Built-in first names include genevive, genevieve, bobby (case-insensitive; matches employee name or business name first word).
# EMAIL_VERIFICATION_BYPASS_FIRST_NAMES=pat,taylor
# EMAIL_VERIFICATION_BYPASS_EMAILS=someone@example.com,other@example.com

# Server
PORT=3001

# Profile / logo uploads (production): Supabase Storage (recommended). Create a **public** bucket named `caretip`
# (or set SUPABASE_STORAGE_BUCKET). Use the service role key only on the server — never in the SPA.
# SUPABASE_URL="https://YOUR_PROJECT.supabase.co"   # optional: omit if you only set NEXT_PUBLIC_SUPABASE_URL at repo root
# SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."
# SUPABASE_STORAGE_BUCKET="caretip"
# Without Supabase, files are stored under ./uploads (needs persistent disk) and URLs use PUBLIC_API_BASE_URL.
# GET /health returns { uploads: { employeeAvatarStorage, supabaseStorageConfigured } } (no secrets) for debugging.
# PUBLIC_API_BASE_URL="https://your-api.example.com"

# Sign-in brute-force protection (optional overrides)
# AUTH_LOGIN_MAX_PER_WINDOW=30

# Verbose [auth.login] console.debug (email + userExists + passwordValid; never logs password). Default on in non-production.
# AUTH_DEBUG_LOGIN=true

# Super Admin seed script extras (optional)
# ALLOW_ADMIN_SEED_IN_PRODUCTION=false
# ALLOW_MULTIPLE_SUPER_ADMINS=false

# Web push (Firebase Cloud Messaging) — optional until you enable browser notifications.
# Server: download service account JSON → save as firebase-service-account.json (gitignored), then:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Alternative (single line only — no line breaks): FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional: ENABLE_PUSH_TEST=true — allows POST /api/push/test in production (disabled by default)
# Public web config (also set VITE_FIREBASE_* at repo root for the SPA + generated service worker):
# FIREBASE_WEB_API_KEY=
# FIREBASE_PROJECT_ID=
# FIREBASE_MESSAGING_SENDER_ID=
# FIREBASE_WEB_APP_ID=
# FIREBASE_WEB_VAPID_KEY=   # Cloud Messaging → Web Push certificates → Key pair
# FIREBASE_AUTH_DOMAIN=     # optional — defaults to PROJECT_ID.firebaseapp.com
# FIREBASE_STORAGE_BUCKET= # optional — defaults to PROJECT_ID.appspot.com
