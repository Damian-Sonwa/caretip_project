// Caretip - PostgreSQL schema via Prisma
// Stormy Teal #197278 | Tomato Jam #C44536
//
// Keep this full schema (User with cuid, Business, Employee, Transaction/tips). A minimal User-only model
// would break auth, sign-in, and tipping flows.

generator client {
  provider = "prisma-client-js"
}

// Single `DATABASE_URL` — Supabase **pooler** only (`*.pooler.supabase.com`). Do not add `directUrl`:
// the direct host `db.*.supabase.co` often fails from this environment (P1001 / routing).
//
// Migrations: `npx prisma migrate deploy` may hang on the transaction pooler (port 6543). If it does, open the
// matching `prisma/migrations/*/migration.sql` in Supabase → SQL Editor, run it, then (from repo root):
//   npm run db:migrate:resolve -- --applied <migration_folder_name>
// or from `backend/` with schema path: `npx prisma migrate resolve --schema prisma/schema.prisma --applied <name>`
// so Prisma’s migration history matches the database.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  SUPER_ADMIN
}

enum BusinessVerificationStatus {
  pending
  verified
  rejected
}

/// Admin-approved platform access (separate from KYC / go-live compliance).
enum OnboardingVerificationStatus {
  draft
  submitted
  approved
  rejected
}

/// Financial / compliance document verification (separate from onboarding approval).
enum KycVerificationStatus {
  not_started
  awaiting_upload
  pending_review
  verified
  rejected
}

enum BusinessSubscriptionTier {
  basic
  premium
  enterprise
}

/// Platform billing plan key — aligns 1:1 with BusinessSubscriptionTier (Phase A).
enum SubscriptionPlanKey {
  basic
  premium
  enterprise
}

enum BillingCycle {
  monthly
  yearly
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
}

enum TrialSource {
  internal
  stripe
}

enum SubscriptionEventProcessingResult {
  processed
  ignored
  failed
}

/// Approval-based sponsored programme access (independent of Stripe Subscription mirror).
enum SponsoredAccessStatus {
  pending
  active
  revoked
  expired
}

enum PayoutStatus {
  pending
  processing
  paid
  failed
  not_applicable
}

enum TipStatus {
  pending
  success
  failed
}

enum GoalPeriod {
  daily
  weekly
  monthly
}

enum EmployeeGoalStatus {
  active
  archived
}

enum EmployeeInviteStatus {
  active
  expired
  revoked
}

enum EmployeeActivationStatus {
  /**
   * Fully onboarded staff (tippable / listed for customers as configured).
   */
  active
  /**
   * Added from business dashboard with activation email; awaiting password setup.
   */
  pending_activation
  /**
   * Self-signup via auth (invite code); `User.email_verified` still false until verify-email link.
   */
  pending_verification
}

enum NotificationPriority {
  normal
  high
}

enum SupportTicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum SupportTicketCategory {
  technical
  billing
  kyc
  feature_request
  general
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  /**
   * Null when the account only uses Google sign-in.
   */
  passwordHash           String?   @map("password_hash")
  /**
   * e.g. google — paired with oauthSubject for IdP lookup.
   */
  oauthProvider          String?   @map("oauth_provider")
  oauthSubject           String?   @map("oauth_subject")
  role                   Role
  emailVerified          Boolean   @default(false) @map("email_verified")
  /**
   * Denormalized flag for platform operators; always true when role is SUPER_ADMIN.
   */
  isPlatformAdmin        Boolean   @default(false) @map("is_platform_admin")
  /**
   * When false, user cannot sign in; used to revoke access without deleting the row.
   */
  isActive               Boolean   @default(true) @map("is_active")
  /**
   * Business-only: whether the manager finished onboarding.
   * Controls post-auth routing to `/onboarding`.
   */
  hasCompletedOnboarding Boolean   @default(false) @map("has_completed_onboarding")
  /**
   * Set only when the manager explicitly finishes onboarding (PATCH /api/auth/me).
   */
  onboardingCompletedAt  DateTime? @map("onboarding_completed_at")
  /**
   * UI + transactional email language: `en` or `de`. Null until user picks a language or registers with a locale hint.
   */
  preferredLocale        String?   @map("preferred_locale")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  business                Business?
  employee                Employee?
  auditLogs               AuditLog[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  refreshTokens           RefreshToken[]
  settings                UserSettings?
  pushDeviceTokens        PushDeviceToken[]
  notifications           Notification[]
  announcementsCreated    Announcement[]           @relation("AnnouncementCreatedBy")
  supportTicketsCreated   SupportTicket[]          @relation("SupportTicketCreatedBy")
  supportTicketMessages   SupportTicketMessage[]   @relation("SupportTicketMessageAuthor")
  employeeInvitesCreated  EmployeeInvite[]         @relation("EmployeeInvitesCreated")
  employeeInviteRedemptions EmployeeInviteRedemption[] @relation("EmployeeInviteRedemptions")
  sponsoredAccessGrantsApproved SponsoredAccessGrant[] @relation("SponsoredAccessGrantsApproved")

  /**
   * Account-level security features (optional; does not change auth flow unless enforced).
   */
  twoFactorEnabled    Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret     String? @map("two_factor_secret")
  twoFactorTempSecret String? @map("two_factor_temp_secret")

  @@unique([oauthProvider, oauthSubject], map: "User_oauth_provider_subject_key")
  @@index([createdAt(sort: Desc)])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  /**
   * Email / in-app preferences
   */
  tipReceivedNotifications Boolean @default(true) @map("tip_received_notifications")
  summaryEmails            Boolean @default(false) @map("summary_emails")
  systemAlerts             Boolean @default(true) @map("system_alerts")
  notifyNewLogin           Boolean @default(true) @map("notify_new_login")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// FCM web push registration for a signed-in user (browser/device).
model PushDeviceToken {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  /**
   * FCM registration token from the browser.
   */
  token      String   @unique
  platform   String   @default("web")
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_device_tokens")
}

/// In-app notification inbox (push/email are delivery channels on the row).
model Notification {
  id        String               @id @default(cuid())
  userId    String               @map("user_id")
  type      String               @db.VarChar(64)
  title     String               @db.VarChar(256)
  message   String               @db.Text
  metadata  Json                 @default("{}")
  priority  NotificationPriority @default(normal)
  /**
   * Channels used for this delivery: in_app, push, email
   */
  channels  String[]             @default(["in_app"])
  readAt    DateTime?            @map("read_at")
  /**
   * Optional dedupe key per user (e.g. tip:id:employee:userId).
   */
  dedupeKey String?              @map("dedupe_key") @db.VarChar(191)
  createdAt DateTime             @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

/// Platform admin broadcast audit record.
model Announcement {
  id             String               @id @default(cuid())
  createdById    String               @map("created_by_id")
  title          String               @db.VarChar(256)
  message        String               @db.Text
  audience       String               @db.VarChar(32)
  priority       NotificationPriority @default(normal)
  channels       String[]             @default(["in_app", "push"])
  url            String?              @db.VarChar(512)
  recipientCount Int                  @default(0) @map("recipient_count")
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now()) @map("created_at")

  createdBy User @relation("AnnouncementCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@map("announcements")
}

/// Business → platform support request (thread body in SupportTicketMessage).
model SupportTicket {
  id              String                @id @default(cuid())
  ticketNumber    String                @unique @map("ticket_number") @db.VarChar(32)
  businessId      String                @map("business_id")
  createdByUserId String                @map("created_by_user_id")
  subject         String                @db.VarChar(256)
  category        SupportTicketCategory
  status          SupportTicketStatus   @default(OPEN)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  closedAt        DateTime?             @map("closed_at")

  business  Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User                   @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  messages  SupportTicketMessage[]

  @@index([businessId, updatedAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@map("support_tickets")
}

model SupportTicketMessage {
  id           String   @id @default(cuid())
  ticketId     String   @map("ticket_id")
  authorUserId String   @map("author_user_id")
  /**
   * `business` (manager) or `admin` (platform operator).
   */
  authorRole   String   @map("author_role") @db.VarChar(16)
  body         String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation("SupportTicketMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("support_ticket_messages")
}

/// Long-lived refresh tokens for session continuity (hashed at rest; rotated on every use).
model RefreshToken {
  id                String    @id @default(cuid())
  tokenHash         String    @unique @map("token_hash")
  userId            String    @map("user_id")
  expiresAt         DateTime  @map("expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  revokedAt         DateTime? @map("revoked_at")
  replacedByTokenId String?   @map("replaced_by_token_id")

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshToken?  @relation("RefreshTokenReplacedBy", fields: [replacedByTokenId], references: [id])
  replaces   RefreshToken[] @relation("RefreshTokenReplacedBy")

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// One-time tokens for email password recovery (stores SHA-256 of the secret segment).
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// One-time tokens for email verification (stores SHA-256 of the secret segment).
model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

/// One-time activation tokens for employee account setup (stores SHA-256 of the secret segment).
/// Allows employee to set their own password after being added by business.
model EmployeeActivationToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique @map("token_hash")
  employeeId String   @map("employee_id")
  email      String   @db.Text
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_activation_tokens")
}

/// Security / compliance trail for sensitive actions (especially platform admin).
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  userId    String   @map("user_id")
  metadata  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model StripeWebhookEvent {
  id          String   @id
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("stripe_webhook_events")
}

model Business {
  id                  String    @id @default(cuid())
  name                String
  /**
   * Public URL segment for team QR: /business/{slug} — required for directory queries & pooler consistency
   */
  slug                String    @unique @map("slug")
  inviteCode          String?   @unique @map("invite_code")
  inviteCodeExpiresAt DateTime? @map("invite_code_expires_at")
  stripeAccountId     String?   @map("stripe_account_id")
  /// Platform Stripe Customer for checkout reuse before a Subscription row exists (Option A).
  stripeCustomerId    String?   @unique @map("stripe_customer_id")
  userId              String    @unique @map("user_id")
  /**
   * IANA timezone used for all dashboard analytics/ranges (e.g. "Europe/Berlin").
   * Timestamps are stored in UTC; queries translate business-local boundaries to UTC.
   */
  timezone            String    @default("Europe/Berlin") @map("timezone")

  verificationStatus       BusinessVerificationStatus @default(pending) @map("verification_status")
  onboardingVerificationStatus OnboardingVerificationStatus @default(draft) @map("onboarding_verification_status")
  kycVerificationStatus    KycVerificationStatus    @default(not_started) @map("kyc_verification_status")
  onboardingSubmittedAt    DateTime?                @map("onboarding_submitted_at")
  onboardingReviewNotes    String?                  @map("onboarding_review_notes") @db.Text
  onboardingReviewHistory  Json?                    @map("onboarding_review_history")
  taxId                    String?                    @map("tax_id")
  legalContactName         String?                    @map("legal_contact_name")
  contactEmail             String?                    @map("contact_email")
  contactPhone             String?                    @map("contact_phone")
  website                  String?                    @map("website")
  registeredAddress        String?                    @map("registered_address") @db.Text
  /**
   * Business type selected during sign-up (e.g. "Restaurant", "Salon", "Hotel", etc).
   */
  businessType             String?                    @map("business_type")
  /**
   * Business location selected during sign-up.
   */
  location                 String?                    @map("location")
  /**
   * Public URL path served under /uploads (e.g. /uploads/platform/businesses/{id}/logo-….png).
   */
  logoPath                 String?                    @map("logo_path")
  /** Premium branding — hero banner on guest landing (public URL). */
  bannerImagePath          String?                    @map("banner_image_path")
  /** Premium branding — QR frame / guest accent (HEX). */
  brandPrimaryColor        String?                    @default("#EB992C") @map("brand_primary_color") @db.VarChar(7)
  brandSecondaryColor      String?                    @default("#000000") @map("brand_secondary_color") @db.VarChar(7)
  /** Premium — guest header welcome line (max 120 chars). */
  welcomeMessage           String?                    @map("welcome_message") @db.VarChar(120)
  /** Premium — post-tip thank-you copy (max 250 chars). */
  thankYouMessage          String?                    @map("thank_you_message") @db.VarChar(250)
  /** Premium v2 — guest-facing display name (QR + tipping); falls back to `name`. */
  brandDisplayName         String?                    @map("brand_display_name") @db.VarChar(80)
  /** Premium v2 — short tagline under display name on QR and guest pages. */
  brandTagline             String?                    @map("brand_tagline") @db.VarChar(120)
  /** Premium v2 — QR visual template preset. */
  qrTemplate               String                     @default("velvet-lounge-noir") @map("qr_template") @db.VarChar(32)
  /** Premium v2 — QR card border style. */
  qrBorderStyle            String                     @default("rounded") @map("qr_border_style") @db.VarChar(32)
  /** Premium v2 — QR module container shape. */
  qrShape                  String                     @default("square") @map("qr_shape") @db.VarChar(32)
  /** Premium v2 — QR frame/accent (falls back to brandPrimaryColor). */
  qrAccentColor            String?                    @map("qr_accent_color") @db.VarChar(7)
  /** Premium v2 — QR card background. */
  qrBackgroundColor        String?                    @default("#FFFFFF") @map("qr_background_color") @db.VarChar(7)
  /**
   * KYC / verification document path under /uploads.
   */
  verificationDocumentPath String?                    @map("verification_document_path")
  /**
   * Manager-uploaded KYC bundle: registration, address, governmentId, additional[].
   */
  kycDocuments             Json?                      @map("kyc_documents")
  kycSubmittedAt           DateTime?                  @map("kyc_submitted_at")
  kycReviewNotes           String?                    @map("kyc_review_notes") @db.Text
  kycReviewHistory         Json?                      @map("kyc_review_history")
  /**
   * Mirrored SaaS tier for read-optimized UI. Not authoritative for authorization — use Subscription + resolver.
   * Null when the business has no active subscription (Option A).
   */
  subscriptionTier         BusinessSubscriptionTier?  @map("subscription_tier")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  employees      Employee[]
  transactions   Transaction[]
  locations      Location[]
  supportTickets SupportTicket[]
  employeeInvites EmployeeInvite[]
  subscription   Subscription?
  sponsoredAccessGrants SponsoredAccessGrant[]
  qrScanEvents   QrScanEvent[]
  qrFunnelEvents QrFunnelEvent[]
  featureUtilizationDaily FeatureUtilizationDaily[]

  @@index([verificationStatus], map: "businesses_verification_status_idx")
  @@index([onboardingVerificationStatus], map: "businesses_onboarding_verification_status_idx")
  @@index([kycVerificationStatus], map: "businesses_kyc_verification_status_idx")
  @@map("businesses")
}

/// Explicit approved sponsored programme grant — never inferred from businessType.
model SponsoredAccessGrant {
  id                 String                @id @default(cuid())
  businessId         String                @map("business_id")
  business           Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  programmeKey       String                @map("programme_key")
  capabilityProfileKey String?               @map("capability_profile_key")
  status             SponsoredAccessStatus @default(pending)
  approvedAt         DateTime?             @map("approved_at")
  approvedByUserId   String?               @map("approved_by_user_id")
  approvedBy         User?                 @relation("SponsoredAccessGrantsApproved", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  expiresAt          DateTime?             @map("expires_at")
  notes              String?               @db.Text
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")

  @@index([businessId, status])
  @@index([programmeKey, status])
  @@map("sponsored_access_grants")
}

/// Manager-generated employee invite codes (multi-use until expiry or rotation).
model EmployeeInvite {
  id              String               @id @default(cuid())
  inviteCode      String               @unique @map("invite_code")
  businessId      String               @map("business_id")
  createdByUserId String               @map("created_by_user_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  expiresAt       DateTime             @map("expires_at")
  status          EmployeeInviteStatus @default(active)

  business    Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy   User                       @relation("EmployeeInvitesCreated", fields: [createdByUserId], references: [id], onDelete: Cascade)
  redemptions EmployeeInviteRedemption[]

  @@index([businessId, status])
  @@index([expiresAt])
  @@map("employee_invites")
}

/// One row per employee who joins via an invite code (audit + redemption history).
model EmployeeInviteRedemption {
  id               String   @id @default(cuid())
  inviteId         String   @map("invite_id")
  redeemedByUserId String   @map("redeemed_by_user_id")
  redeemedAt       DateTime @default(now()) @map("redeemed_at")
  employeeId       String   @map("employee_id")
  inviteeEmail     String   @map("invitee_email")
  inviteeName      String   @map("invitee_name")

  invite     EmployeeInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  redeemedBy User           @relation("EmployeeInviteRedemptions", fields: [redeemedByUserId], references: [id], onDelete: Cascade)
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([inviteId, redeemedByUserId])
  @@index([inviteId, redeemedAt])
  @@index([redeemedByUserId])
  @@map("employee_invite_redemptions")
}

model Location {
  id           String        @id @default(cuid())
  name         String
  description  String?       @db.Text
  businessId   String        @map("business_id")
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tables       Table[]
  transactions Transaction[]
  employees    Employee[]
  qrScanEvents QrScanEvent[]

  @@index([businessId])
  @@map("locations")
}

model Table {
  id                       String                    @id @default(cuid())
  name                     String
  /**
   * Unique segment for guest URLs: GET /api/tipping-context/:qrSlug
   */
  qrSlug                   String                    @unique @map("qr_slug")
  locationId               String                    @map("location_id")
  location                 Location                  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  transactions             Transaction[]
  employeeTableAssignments EmployeeTableAssignment[]
  qrScanEvents             QrScanEvent[]

  @@map("venue_tables")
}

/// Explicit join for Employee ↔ venue `Table` (Postgres `_EmployeeTableAssignments`, columns A/B).
/// Named explicitly so Prisma matches `db push` / Supabase — implicit M2M used `_EmployeeToTable` and caused P2021.
/// `employeeName` denormalizes `employees.name` for audit / SQL without joining `employees`.
model EmployeeTableAssignment {
  employeeId   String @map("A")
  tableId      String @map("B")
  employeeName String @map("employee_name")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  table    Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@id([employeeId, tableId])
  @@index([tableId], map: "_EmployeeTableAssignments_B_index")
  @@map("_EmployeeTableAssignments")
}

model Employee {
  id                 String                   @id @default(cuid())
  name               String
  slug               String?                  @unique
  jobTitle           String                   @map("job_title")
  bio                String?                  @db.Text
  avatar             String?
  phone              String?
  monthlyGoal        Decimal?                 @map("monthly_goal") @db.Decimal(10, 2)
  emailNotifications Boolean                  @default(true) @map("email_notifications")
  pushNotifications  Boolean                  @default(true) @map("push_notifications")
  isActive           Boolean                  @default(true) @map("is_active")
  /** Soft delete — row retained for tips ledger and analytics. */
  isDeleted          Boolean                  @default(false) @map("is_deleted")
  deletedAt          DateTime?                @map("deleted_at")
  /**
   * `active` = ready for work flows; `pending_activation` = dashboard invite, needs `/activate`;
   * `pending_verification` = auth-page invite signup, needs email verification.
   */
  activationStatus   EmployeeActivationStatus @default(active) @map("activation_status")
  businessId         String                   @map("business_id")
  /**
   * Always set: every staff member has a row in `User` (auth account), including invite/activation flows
   * before password is chosen. `User.email_verified` may still be false until they verify or complete activation.
   */
  userId             String                   @unique @map("user_id")
  /**
   * Optional venue for multi-QR flows; must belong to the same business.
   */
  locationId         String?                  @map("location_id")

  business         Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location         Location?                 @relation(fields: [locationId], references: [id], onDelete: SetNull)
  transactions     Transaction[]
  tableAssignments EmployeeTableAssignment[]
  employeeGoals    EmployeeGoal[]
  activationTokens EmployeeActivationToken[]
  inviteRedemptions EmployeeInviteRedemption[]
  qrScanEvents      QrScanEvent[]

  @@index([businessId, locationId])
  @@index([businessId, isActive, name])
  @@index([businessId, isDeleted])
  @@map("employees")
}

/// Employee-created tip goals (multiple rows per employee). Business has read-only visibility via stats API.
model EmployeeGoal {
  id         String             @id @default(cuid())
  employeeId String             @map("employee_id")
  name       String             @default("Tip goal")
  goalAmount Decimal            @map("goal_amount") @db.Decimal(10, 2)
  goalPeriod GoalPeriod         @map("goal_period")
  status     EmployeeGoalStatus @default(active)
  startDate  DateTime           @map("start_date") @db.Date
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([employeeId, status, updatedAt(sort: Desc)])
  @@map("employee_goals")
}

/// Payment / tip transaction (Stripe PaymentIntent). DB table remains `tips` for zero-downtime migrations.
/// Optional locationId/tableId: physical table QR context only — never required for auth.
model Transaction {
  id                    String       @id @default(cuid())
  amount                Decimal      @db.Decimal(10, 2)
  status                TipStatus    @default(pending)
  stripePaymentIntentId String?      @unique @map("stripe_payment_intent_id")
  /// Customer-facing receipt reference (e.g. CT-2026-48291). Assigned when status becomes success.
  receiptNumber         String?      @unique @map("receipt_number")
  payoutStatus          PayoutStatus @default(not_applicable) @map("payout_status")
  employeeId            String       @map("employee_id")
  businessId            String       @map("business_id")
  locationId            String?      @map("location_id")
  tableId               String?      @map("table_id")
  createdAt             DateTime     @default(now()) @map("created_at")

  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  table    Table?       @relation(fields: [tableId], references: [id], onDelete: SetNull)
  feedback TipFeedback?

  @@index([businessId])
  @@index([employeeId, status, createdAt(sort: Desc)])
  @@index([businessId, status, createdAt(sort: Desc)])
  @@index([employeeId, status, payoutStatus])
  @@map("tips")
}

/// Monotonic per-calendar-year counter for CareTip receipt numbers (CT-YYYY-NNNNN).
model TipReceiptSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("tip_receipt_sequences")
}

/// Optional customer feedback tied to a *successful* tip transaction.
/// Public pages submit feedback using the Stripe Checkout session id, which the API
/// validates and maps to `Transaction` via payment_intent.
model TipFeedback {
  id                      String  @id @default(cuid())
  transactionId           String  @unique @map("transaction_id")
  businessId              String  @map("business_id")
  employeeId              String  @map("employee_id")
  locationId              String? @map("location_id")
  tableId                 String? @map("table_id")
  stripeCheckoutSessionId String? @map("stripe_checkout_session_id")

  rating       Int?     @db.SmallInt
  comment      String?  @db.Text
  tags         String[]
  customerName String?  @map("customer_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([employeeId])
  @@index([createdAt])
  @@map("tip_feedback")
}

/// Platform SaaS subscription mirror (Phase A — table only; reads still use Business.subscriptionTier).
model Subscription {
  id                    String               @id @default(cuid())
  businessId            String               @unique @map("business_id")
  business              Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)

  planKey               SubscriptionPlanKey  @map("plan_key")
  billingCycle          BillingCycle         @default(monthly) @map("billing_cycle")
  status                SubscriptionStatus   @default(incomplete)

  /// Platform fee in cents (optional premium); null for basic tip-fees-only.
  platformFeeCents      Int?                 @map("platform_fee_cents")

  trialSource           TrialSource?         @map("trial_source")
  trialStartedAt        DateTime?            @map("trial_started_at")
  trialEndsAt           DateTime?            @map("trial_ends_at")
  /// True while Stripe status is trialing (synced from webhooks).
  isTrial               Boolean              @default(false) @map("is_trial")
  /// Tracks which trial reminder emails were sent, e.g. {"7":"2026-06-17T…","3":"…","1":"…"}.
  trialReminderSent     Json?                @map("trial_reminder_sent")
  /// Set when the subscription transitions from trialing to active (first successful charge).
  trialExpiredAt        DateTime?            @map("trial_expired_at")

  currentPeriodStart    DateTime?            @map("current_period_start")
  currentPeriodEnd      DateTime?            @map("current_period_end")
  renewalDate           DateTime?            @map("renewal_date")

  cancelAtPeriodEnd     Boolean              @default(false) @map("cancel_at_period_end")
  canceledAt            DateTime?            @map("canceled_at")
  cancellationEffective DateTime?            @map("cancellation_effective")

  stripeCustomerId      String?              @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?              @unique @map("stripe_subscription_id")
  stripePriceId         String?              @map("stripe_price_id")

  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  events                SubscriptionEvent[]

  @@index([status])
  @@index([renewalDate])
  @@map("subscriptions")
}

/// Subscription lifecycle audit trail and future webhook idempotency (Phase A).
model SubscriptionEvent {
  id                String                            @id @default(cuid())
  subscriptionId    String?                           @map("subscription_id")
  subscription      Subscription?                     @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  auditType         String                            @map("audit_type")
  type              String?                           @map("type")
  stripeEventId     String?                           @unique @map("stripe_event_id")

  processingResult  SubscriptionEventProcessingResult @map("processing_result")
  processingError   String?                           @map("processing_error")
  payload           Json?
  occurredAt        DateTime                          @default(now()) @map("occurred_at")
  processedAt       DateTime?                         @map("processed_at")

  @@index([subscriptionId, occurredAt])
  @@index([auditType, occurredAt])
  @@map("subscription_events")
}

/// Sprint 4 — durable QR scan analytics (one row per attributed scan).
model QrScanEvent {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  employeeId String?  @map("employee_id")
  locationId String?  @map("location_id")
  tableId    String?  @map("table_id")
  qrSlug     String?  @map("qr_slug") @db.VarChar(128)
  scanType   String   @map("scan_type") @db.VarChar(32)
  entryPath  String   @map("entry_path") @db.VarChar(512)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  deviceType String   @map("device_type") @db.VarChar(32)
  country    String?  @db.VarChar(64)
  city       String?  @db.VarChar(128)
  scannedAt  DateTime @default(now()) @map("scanned_at")
  sessionId  String   @map("session_id") @db.VarChar(64)
  dedupeKey  String   @unique @map("dedupe_key") @db.VarChar(191)

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  table    Table?    @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([businessId, scannedAt(sort: Desc)])
  @@index([employeeId, scannedAt(sort: Desc)])
  @@index([locationId, scannedAt(sort: Desc)])
  @@index([tableId, scannedAt(sort: Desc)])
  @@map("qr_scan_events")
}

/// Sprint 4F — conversion funnel foundation (tip_started, payment_completed). Not exposed in UI yet.
model QrFunnelEvent {
  id            String   @id @default(cuid())
  businessId    String   @map("business_id")
  sessionId     String   @map("session_id") @db.VarChar(64)
  eventType     String   @map("event_type") @db.VarChar(32)
  employeeId    String?  @map("employee_id")
  locationId    String?  @map("location_id")
  tableId       String?  @map("table_id")
  transactionId String?  @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt(sort: Desc)])
  @@index([sessionId, createdAt(sort: Desc)])
  @@map("qr_funnel_events")
}

/// Sprint 7B — daily feature utilization rollups per business.
model FeatureUtilizationDaily {
  id         String   @id @default(cuid())
  businessId String   @map("business_id")
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  featureKey String   @map("feature_key") @db.VarChar(48)
  day        DateTime @db.Date
  hitCount   Int      @default(1) @map("hit_count")
  lastUsedAt DateTime @default(now()) @map("last_used_at")

  @@unique([businessId, featureKey, day])
  @@index([businessId, day])
  @@map("feature_utilization_daily")
}
